{
  "manifest_version": 3,
  "name": "Hive Browser Bridge",
  "version": "1.0.0",
  "description": "Connects Hive AI subagents to your existing browser via isolated tab groups",
  "permissions": [
    "debugger",
    "tabs",
    "tabGroups",
    "offscreen",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hive Browser Bridge",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
